[Unit]
Description=Kurs site sync worker
After=network.target rabbitmq-server.service

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/Documents/kurs_update
ExecStart=/home/ubuntu/Documents/kurs_update/.venv/bin/python /home/ubuntu/Documents/kurs_update/sync_worker.py
Restart=always
RestartSec=5
User=ubuntu
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target

